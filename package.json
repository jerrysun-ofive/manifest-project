{
  "name": "inline-form-builder",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend && npm run build --prefix backend",
    "test": "npm run test --prefix frontend && npm run test --prefix backend",
    "test:frontend": "npm run test --prefix frontend",
    "test:backend": "npm run test --prefix backend",
    "test:e2e": "npm run test:e2e --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "ci": "npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
